# Copy to .env.local and fill in values from your AWS SAM stack outputs

# ── Todo service (vocmap-todo-service-dev outputs) ────────────────────────────
VITE_API_TODO_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/dev

# ── Keyword service (vocmap-keyword-service-dev outputs) ──────────────────────
VITE_API_KEYWORD_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/dev

# ── Vocabulary service (vocmap-vocabulary-service-dev outputs) ────────────────
VITE_API_VOCAB_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/dev

# ── Cognito (vocmap-infra-dev outputs) ────────────────────────────────────────
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_AWS_REGION=us-east-1
